# Public URL of this deployment (used in OAuth metadata + redirects).
# Example: https://soi-mcp.vercel.app
PUBLIC_URL=

# Static password the user types into the OAuth consent screen.
# Pick something long and random.
CONNECTOR_PASSWORD=

# HMAC secret used to sign OAuth artifacts (client IDs, auth codes, access tokens).
# At least 32 chars. Rotate this to invalidate every issued access token.
# Generate with:  openssl rand -base64 48
JWT_SECRET=

# Klaviyo Private API Key (pk_xxx). Generate one at:
#   https://www.klaviyo.com/account#api-keys-tab
# Required scopes: Templates R/W, Segments R/W, Lists R/W, Profiles R/W, Flows R/W.
KLAVIYO_API_KEY=

# Klaviyo API revision header. Pin this so the schema doesn't shift under us.
KLAVIYO_API_REVISION=2026-04-15
